{
  "kind": "collectionType",
  "collectionName": "knowledge_documents",
  "info": {
    "singularName": "knowledge-document",
    "pluralName": "knowledge-documents",
    "displayName": "Knowledge document",
    "description": "База знаний для будущего AI-ассистента (RAG)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
