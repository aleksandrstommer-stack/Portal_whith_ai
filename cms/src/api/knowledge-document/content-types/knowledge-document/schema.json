    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "abstract": {
      "type": "text"
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "tags": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "embeddingMeta": {
      "type": "json",
      "private": false
    }
  }
