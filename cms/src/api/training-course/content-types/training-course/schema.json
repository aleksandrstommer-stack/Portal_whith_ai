{
  "kind": "collectionType",
  "collectionName": "training_courses",
  "info": {
    "singularName": "training-course",
    "pluralName": "training-courses",
    "displayName": "Программа обучения",
    "description": "Курсы и материалы обучения"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text",
      "required": true
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "durationHours": {
      "type": "decimal",
      "default": 1
    },
    "level": {
      "type": "enumeration",
      "enum": ["beginner", "intermediate", "advanced"],
      "default": "beginner",
      "required": true
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
