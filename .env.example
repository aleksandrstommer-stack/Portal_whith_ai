# Для чата с RAG нужен pgvector. При проблемах с Docker Hub: postgres:16-alpine (без векторов).
POSTGRES_IMAGE=pgvector/pgvector:pg16

OLLAMA_PORT=11434
# По умолчанию проект ожидает нативный Ollama на хосте (Mac): http://host.docker.internal:11434
# Если хотите использовать контейнер ollama из compose, задайте: http://ollama:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Приоритет адресов Ollama: сначала хост (GPU/Metal на Mac), затем контейнер (обычно CPU)
OLLAMA_BASE_URLS=http://host.docker.internal:11434,http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

RAG_DATABASE_URL=postgresql://strapi:strapi@localhost:5432/strapi
RAG_EMBEDDING_DIM=768

# Strapi (в Docker те же значения в compose): эмбеддинги при сохранении «Векторная база знаний»
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Опционально: ID или полная ссылка на Google Doc — при первом запросе в /api/chat индекс поднимется сам (документ должен быть «по ссылке» для чтения).
# RAG_BOOTSTRAP_GOOGLE_DOC_ID=1abc..._yourDocId

# Секрет для POST /api/rag/import-google-doc (в production обязателен)
# RAG_IMPORT_SECRET=change-me-import-secret

POSTGRES_USER=strapi
POSTGRES_PASSWORD=strapi
POSTGRES_DB=strapi
POSTGRES_PORT=5433

STRAPI_PORT=1337
FRONTEND_PORT=3000

# С браузера: на Ubuntu укажите IP/домен, иначе картинки в чате не откроются.
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# STRAPI_PUBLIC_URL=http://10.0.0.1:1337
STRAPI_INTERNAL_URL=http://strapi:1337
# RAG_MAX_COSINE_DISTANCE=0.58

APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=change-me
ADMIN_JWT_SECRET=change-me
TRANSFER_TOKEN_SALT=change-me
JWT_SECRET=change-me
